    {
      "table": "sungnam_service_inflow_pop",
      "name": "성남시 서비스 유입 인구 통계",
      "description": "성남시 유입 인구(주거/직장/방문) 집계 테이블.",
      "domain": "population",
      "tags": [
        "#인구",
        "#유입",
        "#시간",
        "#지역"
      ],
      "synonyms": [
        "유입 인구",
        "서비스 인구"
      ],
      "dimensions": {
        "time": [
          "std_ym",
          "std_ymd",
          "time"
        ],
        "location": [
          "inflow_cd",
          "hcode"
        ]
      },
      "joins": [
        {
          "column": "hcode",
          "ref_table": "place_codes",
          "ref_column": "admin_code",
          "ref_name": "name",
          "description": "행정동 코드(hcode)는 place_codes.admin_code와 매핑. 유입 인구의 도착/체류 지역을 의미한다."
        },
        {
          "column": "inflow_cd",
          "ref_table": "place_codes",
          "ref_column": "code",
          "ref_name": "name",
          "description": "유입지 코드(inflow_cd)는 place_codes.code와 매핑. 유입 인구의 출발 지역을 의미한다.",
          "sql_hint": "JOIN place_codes pc ON t1.inflow_cd = LEFT(pc.code, 5)"
        }
      ],
      "constraints": [
        "place_codes.created_at IS NULL OR place_codes.created_at <= '{std_ymd}'",
        "place_codes.abolished_at IS NULL OR place_codes.abolished_at >= '{std_ymd}'"
      ],
      "measures": [
        "h_pop",
        "w_pop",
        "v_pop"
      ],
