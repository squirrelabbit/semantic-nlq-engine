    {
      "table": "place_codes",
      "name": "지역 및 행정 구역 코드 정보",
      "description": "행정동/시군구 코드와 명칭을 제공하며, 유효 기간 제약을 포함한다.",
      "domain": "geography",
      "tags": [
        "#지역",
        "#행정",
        "#코드"
      ],
      "synonyms": [
        "행정동 코드",
        "지역 코드",
        "지역명",
        "법정동",
        "시군구"
      ],
      "dimensions": {
        "location": [
          "code",
          "admin_code",
          "name",
          "sgng_cd"
        ],
        "time": [
          "created_at",
          "abolished_at"
        ]
      },
      "constraints": [
        "place_codes.created_at IS NULL OR place_codes.created_at <= '{std_ymd}'",
        "place_codes.abolished_at IS NULL OR place_codes.abolished_at >= '{std_ymd}'"
      ],
      "joins": [],
      "measures": [],
